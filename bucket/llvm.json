{
    "version": "22.1.1",
    "description": "Collection of modular and reusable compiler and toolchain technologies.",
    "homepage": "https://www.llvm.org",
    "license": "NCSA",
    "notes": "Since upstream does NOT provide pre-compiled binary of arm64 for every release, LLVM arm64 is now a separate manifest: 'llvm-arm64'.",
    "architecture": {
        "64bit": {
            "url": "https://mirrors.tuna.tsinghua.edu.cn/github-release/llvm/llvm-project/LatestRelease/LLVM-22.1.1-win64.exe#/dl.7z",
            "hash": "e7fec06b4696be82bf8d4b846ebf6b810ed6f27d9eefdce46baf5330ea6e9ed4"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall.exe\" -Recurse -ErrorAction Ignore",
    "env_add_path": "bin",
    "env_set": {
        "LIBCLANG_PATH": "$dir\\bin",
        "LLVM_LIB_DIR": "$dir\\lib"
    },
    "checkver": {
        "url": "https://mirrors.tuna.tsinghua.edu.cn/github-release/llvm/llvm-project/LatestRelease/",
        "regex": "LLVM-([\\d._]+)-"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://mirrors.tuna.tsinghua.edu.cn/github-release/llvm/llvm-project/LatestRelease/LLVM-$version-win64.exe#/dl.7z"
            }
        }
    }
}
